import React, { useState } from 'react';
import { Plus, Trash2, Droplets, Layers, Truck, Sparkles, X, FileText } from 'lucide-react';

const DEFAULT_COSTS = {
  500: { lid: 125, eb: 30, gas: 360, labour: 50, packing: 50, maintenance: 20 },
  750: { lid: 100, eb: 50, gas: 735, labour: 100, packing: 60, maintenance: 20 },
  1000: { lid: 100, eb: 50, gas: 735, labour: 150, packing: 80, maintenance: 30 },
  1500: { lid: 100, eb: 50, gas: 1470, labour: 150, packing: 80, maintenance: 30 },
  2000: { lid: 125, eb: 50, gas: 1470, labour: 200, packing: 80, maintenance: 50 },
};

const TANK_SIZES = [500, 750, 1000, 1500, 2000];
const INITIAL_LAYERS = 3;
const INITIAL_PRICES = [184, 71, 146, 0, 0];
const INITIAL_TANKS = [
  { id: 1, size: 500, weights: [5, 3, 4.5, 0, 0], costs: { ...DEFAULT_COSTS[500], transport: 50 } },
  { id: 2, size: 1000, weights: [9, 5.5, 8.2, 0, 0], costs: { ...DEFAULT_COSTS[1000], transport: 100 } }
];

const callGemini = async (prompt, systemInstruction) => {
  const apiKey = "REPLACE_WITH_YOUR_KEY"; 
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
  
  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
    systemInstruction: { parts: [{ text: systemInstruction }] }
  };

  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text || "No response generated.";
  } catch (err) {
    return "Error connecting to AI assistant.";
  }
};

export default function App() {
  const [numLayers, setNumLayers] = useState(INITIAL_LAYERS);
  const [layerPrices, setLayerPrices] = useState(INITIAL_PRICES);
  const [tanks, setTanks] = useState(INITIAL_TANKS);
  const [aiLoading, setAiLoading] = useState(false);
  const [aiModal, setAiModal] = useState({ isOpen: false, title: '', content: '' });

  const formatCurrency = (amount) => `₹${parseFloat(amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 })}`;

  const handlePriceChange = (index, value) => {
    const newPrices = [...layerPrices];
    newPrices[index] = parseFloat(value) || 0;
    setLayerPrices(newPrices);
  };

  const addTank = () => {
    setTanks([...tanks, { id: Date.now(), size: 500, weights: [0,0,0,0,0], costs: { ...DEFAULT_COSTS[500], transport: 0 } }]);
  };

  const removeTank = (id) => setTanks(tanks.filter(t => t.id !== id));

  const handleTankChange = (id, field, value) => {
    setTanks(tanks.map(t => {
      if (t.id === id) {
        if (field === 'size') {
          const newSize = parseInt(value, 10);
          return { ...t, size: newSize, costs: { ...t.costs, ...DEFAULT_COSTS[newSize] } };
        }
        return { ...t, [field]: parseFloat(value) || 0 };
      }
      return t;
    }));
  };

  const handleWeightChange = (id, layerIndex, value) => {
    setTanks(tanks.map(t => {
      if (t.id === id) {
        const newWeights = [...t.weights];
        newWeights[layerIndex] = parseFloat(value) || 0;
        return { ...t, weights: newWeights };
      }
      return t;
    }));
  };

  const handleCostChange = (id, costField, value) => {
    setTanks(tanks.map(t => {
      if (t.id === id) return { ...t, costs: { ...t.costs, [costField]: parseFloat(value) || 0 } };
      return t;
    }));
  };

  const calculateTankTotals = (tank) => {
    let materialCost = 0;
    let totalWeight = 0;
    for (let i = 0; i < numLayers; i++) {
      materialCost += (tank.weights[i] || 0) * (layerPrices[i] || 0);
      totalWeight += (tank.weights[i] || 0);
    }
    const { lid, eb, gas, labour, packing, maintenance, transport } = tank.costs;
    const additionalCosts = (lid||0) + (eb||0) + (gas||0) + (labour||0) + (packing||0) + (maintenance||0);
    const totalCost = materialCost + additionalCosts + (transport || 0);
    return { materialCost, totalWeight, additionalCosts, totalCost, costPerLitre: tank.size > 0 ? (totalCost / tank.size) : 0 };
  };

  return (
    <div className="max-w-md mx-auto bg-slate-100 min-h-screen font-sans">
      <div className="bg-blue-600 p-4 flex items-center gap-3 text-white shadow-lg sticky top-0 z-10">
        <Droplets />
        <h1 className="font-bold text-lg">Tank Cost Calculator</h1>
      </div>

      <div className="p-4 space-y-4">
        <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200">
          <h2 className="flex items-center gap-2 font-bold mb-3"><Layers size={16} className="text-blue-600"/>Layers & Pricing</h2>
          <div className="flex gap-2 mb-4">
            {[1,2,3,4,5].map(n => (
              <button key={n} onClick={() => setNumLayers(n)} className={`flex-1 py-2 rounded-lg font-bold ${numLayers === n ? 'bg-blue-600 text-white' : 'bg-slate-100'}`}>{n}</button>
            ))}
          </div>
          <div className="grid grid-cols-2 gap-2">
            {Array.from({length: numLayers}).map((_, i) => (
              <div key={i}>
                <label className="text-[10px] text-slate-400 uppercase font-bold">Layer {i+1} (₹/kg)</label>
                <input type="number" value={layerPrices[i]||''} onChange={(e) => handlePriceChange(i, e.target.value)} className="w-full border rounded p-2 text-sm"/>
              </div>
            ))}
          </div>
        </div>

        {tanks.map(tank => {
          const totals = calculateTankTotals(tank);
          return (
            <div key={tank.id} className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 relative">
              <button onClick={() => removeTank(tank.id)} className="absolute top-4 right-4 text-red-500"><Trash2 size={16}/></button>
              <h2 className="font-bold mb-2">Tank Size (L)</h2>
              <select value={tank.size} onChange={(e) => handleTankChange(tank.id, 'size', e.target.value)} className="w-full p-2 border rounded-lg bg-slate-50 mb-4 font-bold text-blue-700">
                {TANK_SIZES.map(s => <option key={s} value={s}>{s} L</option>)}
              </select>
              
              <div className="grid grid-cols-2 gap-2 mb-4">
                {Array.from({length: numLayers}).map((_, i) => (
                  <div key={i}>
                    <label className="text-[10px] text-slate-400 uppercase font-bold">L{i+1} Weight (kg)</label>
                    <input type="number" value={tank.weights[i]||''} onChange={(e) => handleWeightChange(tank.id, i, e.target.value)} className="w-full border rounded p-2 text-sm"/>
                  </div>
                ))}
              </div>

              <div className="grid grid-cols-3 gap-2">
                {['lid','eb','gas','labour','packing','maintenance', 'transport'].map(key => (
                  <div key={key}>
                    <label className="text-[10px] text-slate-400 uppercase font-bold">{key}</label>
                    <input type="number" value={tank.costs[key]||''} onChange={(e) => handleCostChange(tank.id, key, e.target.value)} className="w-full border rounded p-2 text-sm"/>
                  </div>
                ))}
              </div>
              
              <div className="mt-4 bg-slate-900 p-4 rounded-lg text-white">
                <div className="flex justify-between">
                  <span>Total Cost:</span> <span className="font-bold">{formatCurrency(totals.totalCost)}</span>
                </div>
                <div className="flex justify-between mt-2 text-emerald-400">
                  <span>Cost/Litre:</span> <span className="font-black text-xl">{formatCurrency(totals.costPerLitre)}/L</span>
                </div>
              </div>
            </div>
          )
        })}

        <button onClick={addTank} className="w-full py-4 border-2 border-dashed rounded-xl font-bold text-blue-600">+ Add Tank</button>
      </div>

      {aiModal.isOpen && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center p-4">
          <div className="bg-white p-6 rounded-xl w-full max-w-sm">
            <div className="flex justify-between items-center mb-4">
              <h3 className="font-bold">{aiModal.title}</h3>
              <button onClick={() => setAiModal({ isOpen: false })}><X/></button>
            </div>
            <p className="text-sm text-slate-600 whitespace-pre-line">{aiModal.content || "Loading..."}</p>
          </div>
        </div>
      )}
    </div>
  );
}
