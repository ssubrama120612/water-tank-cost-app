import React, { useState } from 'react';
import { StyleSheet, Text, View, ScrollView, TextInput, TouchableOpacity, SafeAreaView, StatusBar } from 'react-native';

// Initial data structure
const DEFAULT_COSTS = {
  500: { lid: 125, eb: 30, gas: 360, labour: 50, packing: 50, maintenance: 20, transport: 50 },
  750: { lid: 100, eb: 50, gas: 735, labour: 100, packing: 60, maintenance: 20, transport: 100 },
  1000: { lid: 100, eb: 50, gas: 735, labour: 150, packing: 80, maintenance: 30, transport: 100 },
};

export default function App() {
  const [numLayers, setNumLayers] = useState(3);
  const [layerPrices, setLayerPrices] = useState([184, 71, 146, 0, 0]);
  const [tanks, setTanks] = useState([
    { id: 1, size: 500, weights: [5, 3, 4.5, 0, 0], costs: DEFAULT_COSTS[500] }
  ]);

  const updateWeight = (tankId, layerIndex, value) => {
    setTanks(tanks.map(t => {
      if (t.id === tankId) {
        const newWeights = [...t.weights];
        newWeights[layerIndex] = parseFloat(value) || 0;
        return { ...t, weights: newWeights };
      }
      return t;
    }));
  };

  const updateCost = (tankId, field, value) => {
    setTanks(tanks.map(t => {
      if (t.id === tankId) {
        return { ...t, costs: { ...t.costs, [field]: parseFloat(value) || 0 } };
      }
      return t;
    }));
  };

  const addTank = () => {
    setTanks([...tanks, { id: Date.now(), size: 500, weights: [0, 0, 0, 0, 0], costs: DEFAULT_COSTS[500] }]);
  };

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="light-content" />
      <View style={styles.header}><Text style={styles.headerTitle}>Tank Cost Calculator</Text></View>
      
      <ScrollView contentContainerStyle={styles.scroll}>
        {/* Layer Section */}
        <View style={styles.card}>
          <Text style={styles.sectionTitle}>Layer Price Configuration (₹/kg)</Text>
          <View style={styles.layerRow}>
            {layerPrices.map((p, i) => (
              <TextInput key={i} style={styles.miniInput} value={String(p)} onChangeText={(v) => {
                const newPrices = [...layerPrices];
                newPrices[i] = parseFloat(v) || 0;
                setLayerPrices(newPrices);
              }} placeholder={`L${i+1}`} keyboardType="numeric" />
            ))}
          </View>
        </View>

        {/* Tank List */}
        {tanks.map((tank) => (
          <View key={tank.id} style={styles.card}>
            <Text style={styles.sectionTitle}>{tank.size}L Tank Configuration</Text>
            
            <Text style={styles.subTitle}>Layer Weights (kg)</Text>
            <View style={styles.layerRow}>
              {tank.weights.map((w, i) => (
                <TextInput key={i} style={styles.miniInput} value={String(w)} onChangeText={(v) => updateWeight(tank.id, i, v)} keyboardType="numeric" />
              ))}
            </View>

            <Text style={styles.subTitle}>Manufacturing & Transport Costs (₹)</Text>
            <View style={styles.costGrid}>
              {Object.entries(tank.costs).map(([key, val]) => (
                <View key={key} style={styles.costItem}>
                  <Text style={styles.costLabel}>{key.toUpperCase()}</Text>
                  <TextInput style={styles.input} value={String(val)} onChangeText={(v) => updateCost(tank.id, key, v)} keyboardType="numeric" />
                </View>
              ))}
            </View>
          </View>
        ))}

        <TouchableOpacity style={styles.addBtn} onPress={addTank}><Text style={styles.addBtnText}>+ Add New Tank</Text></TouchableOpacity>
      </ScrollView>
    </SafeAreaView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#f8fafc' },
  header: { backgroundColor: '#2563eb', padding: 20, alignItems: 'center' },
  headerTitle: { color: 'white', fontWeight: 'bold', fontSize: 20 },
  scroll: { padding: 16 },
  card: { backgroundColor: 'white', padding: 16, borderRadius: 12, marginBottom: 16, elevation: 2 },
  sectionTitle: { fontWeight: 'bold', fontSize: 16, marginBottom: 12, color: '#1e293b' },
  subTitle: { fontSize: 12, color: '#64748b', marginBottom: 8, marginTop: 4 },
  layerRow: { flexDirection: 'row', justifyContent: 'space-between' },
  miniInput: { width: '18%', borderWidth: 1, borderColor: '#e2e8f0', borderRadius: 6, padding: 8, textAlign: 'center' },
  costGrid: { flexDirection: 'row', flexWrap: 'wrap', justifyContent: 'space-between' },
  costItem: { width: '48%', marginBottom: 10 },
  costLabel: { fontSize: 10, color: '#94a3b8' },
  input: { borderWidth: 1, borderColor: '#e2e8f0', borderRadius: 6, padding: 8, marginTop: 4 },
  addBtn: { backgroundColor: '#eff6ff', padding: 16, alignItems: 'center', borderRadius: 10, borderStyle: 'dashed', borderWidth: 2, borderColor: '#3b82f6' },
  addBtnText: { color: '#2563eb', fontWeight: 'bold' }
});
