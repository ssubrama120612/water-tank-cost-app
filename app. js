import React, { useState } from 'react';
import { StyleSheet, Text, View, ScrollView, TextInput, TouchableOpacity, SafeAreaView, Modal, ActivityIndicator, StatusBar } from 'react-native';
import { Droplets, Layers, Trash2, Truck, Star, X, Plus, FileText } from 'lucide-react-native';
import { StatusBar as ExpoStatusBar } from 'expo-status-bar';

const DEFAULT_COSTS = {
  500: { lid: 125, eb: 30, gas: 360, labour: 50, packing: 50, maintenance: 20 },
  750: { lid: 100, eb: 50, gas: 735, labour: 100, packing: 60, maintenance: 20 },
  1000: { lid: 100, eb: 50, gas: 735, labour: 150, packing: 80, maintenance: 30 },
  1500: { lid: 100, eb: 50, gas: 1470, labour: 150, packing: 80, maintenance: 30 },
  2000: { lid: 125, eb: 50, gas: 1470, labour: 200, packing: 80, maintenance: 50 },
};

const TANK_SIZES = [500, 750, 1000, 1500, 2000];

export default function App() {
  const [numLayers, setNumLayers] = useState(3);
  const [layerPrices, setLayerPrices] = useState([184, 71, 146, 0, 0]);
  const [tanks, setTanks] = useState([
    { id: 1, size: 500, weights: [5, 3, 4.5, 0, 0], costs: { ...DEFAULT_COSTS[500], transport: 50 } }
  ]);

  const formatCurrency = (amount) => `₹${parseFloat(amount || 0).toFixed(2)}`;

  const handleWeightChange = (id, index, val) => {
    setTanks(tanks.map(t => t.id === id ? { ...t, weights: t.weights.map((w, i) => i === index ? parseFloat(val) || 0 : w) } : t));
  };

  const handleCostChange = (id, field, val) => {
    setTanks(tanks.map(t => t.id === id ? { ...t, costs: { ...t.costs, [field]: parseFloat(val) || 0 } } : t));
  };

  const addTank = () => setTanks([...tanks, { id: Date.now(), size: 500, weights: [0,0,0,0,0], costs: { ...DEFAULT_COSTS[500], transport: 0 } }]);

  return (
    <SafeAreaView style={styles.container}>
      <ExpoStatusBar style="light" />
      <View style={styles.header}><Text style={styles.headerTitle}>Tank Cost Calculator</Text></View>
      <ScrollView contentContainerStyle={styles.scroll}>
        
        {/* Layer Input Section */}
        <View style={styles.card}>
          <Text style={styles.cardTitle}>1. Layers & Material Price</Text>
          <View style={styles.row}>
            {[1,2,3,4,5].map(n => (
              <TouchableOpacity key={n} onPress={() => setNumLayers(n)} style={[styles.btn, numLayers === n && styles.activeBtn]}>
                <Text style={numLayers === n ? {color:'white'} : {}}>{n}</Text>
              </TouchableOpacity>
            ))}
          </View>
        </View>

        {/* Tank List */}
        {tanks.map(tank => (
          <View key={tank.id} style={styles.card}>
            <Text>Tank Size: {tank.size}L</Text>
            {/* Add inputs here for Weights, Costs, and Transport */}
            <Text>Transport Cost (₹)</Text>
            <TextInput 
              style={styles.input} 
              keyboardType="numeric" 
              value={String(tank.costs.transport || '')} 
              onChangeText={(val) => handleCostChange(tank.id, 'transport', val)} 
            />
          </View>
        ))}

        <TouchableOpacity style={styles.addBtn} onPress={addTank}><Text>+ Add Tank</Text></TouchableOpacity>
      </ScrollView>
    </SafeAreaView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#f1f5f9' },
  header: { backgroundColor: '#2563eb', padding: 20, alignItems: 'center' },
  headerTitle: { color: 'white', fontWeight: 'bold', fontSize: 18 },
  scroll: { padding: 16 },
  card: { backgroundColor: 'white', padding: 16, borderRadius: 10, marginBottom: 16 },
  cardTitle: { fontWeight: 'bold', marginBottom: 10 },
  row: { flexDirection: 'row', justifyContent: 'space-around' },
  btn: { padding: 10, backgroundColor: '#e2e8f0', borderRadius: 5 },
  activeBtn: { backgroundColor: '#2563eb' },
  input: { borderWidth: 1, borderColor: '#ccc', padding: 8, borderRadius: 5, marginTop: 5 },
  addBtn: { padding: 15, backgroundColor: '#dbeafe', alignItems: 'center', borderRadius: 10 }
});
